                                    <img src="gallery01.jpg" alt="Hall" class="w-full h-full object-cover img-elegant">
                                    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover/img:opacity-100 transition-opacity flex items-center justify-center">
                                        <span class="text-white font-bold tracking-widest uppercase text-xs border border-white px-4 py-2">Esplora</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </li>

                <!-- Sistemazioni -->
                <li class="group py-6">
                    <a href="#" class="nav-item-link relative inline-block">Sistemazioni</a>
                    <div class="mega-menu-content bg-white text-alpine-text shadow-2xl border-t border-alpine-border cursor-default">
                        <div class="max-w-screen-2xl mx-auto px-6 py-12 grid grid-cols-12 gap-12">
                            <div class="col-span-3">
                                <h4 class="font-serif text-3xl mb-6 text-alpine-text capitalize tracking-normal">Sistemazioni</h4>
                                <ul class="space-y-4 text-sm font-normal normal-case tracking-normal">
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Camera Matrimoniale</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Camera Tripla</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Quadrupla Standard</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Suite Familiare</a></li>
