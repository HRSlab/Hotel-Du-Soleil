<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hotel du Soleil | Modern Alpine Retreat</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts: Cormorant Garamond (Eleganza) & Inter (Pulizia) -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Cormorant Garamond', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        alpine: {
                            bg: '#FAF9F6',      /* Panna/Bianco caldo */
                            text: '#2C3333',    /* Ardesia scuro */
                            muted: '#5C6363',   /* Grigio neutro */
                            border: '#E5E5E0',  /* Bordo leggero */
                            gold: '#B89872'     /* Oro desaturato per accenti */
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #FAF9F6;
            color: #2C3333;
            scroll-behavior: smooth;
        }

        /* --- ANIMAZIONI --- */
        .ken-burns {
            animation: kenBurns 25s ease-out infinite alternate;
        }
        @keyframes kenBurns {
            0% { transform: scale(1); }
            100% { transform: scale(1.08); }
        }

        .img-elegant {
            filter: brightness(0.9) contrast(1.05);
            transition: filter 0.8s ease, transform 1.2s ease;
        }
        .group:hover .img-elegant {
            filter: brightness(1) contrast(1.1);
            transform: scale(1.03);
        }

        .deco-line {
            width: 1px;
            height: 80px;
            background-color: #D6D3CD;
            margin: 0 auto;
        }

        /* --- FADE UP OBSERVER --- */
        .fade-up-element {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .fade-up-element.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- NAVBAR & MEGA MENU --- */
        #navbar {
            transition: background-color 0.4s ease, padding 0.4s ease, color 0.4s ease, box-shadow 0.4s ease;
        }
        .mega-menu-content {
            opacity: 0;
            visibility: hidden;
            transform: translateY(15px);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
        }
        .group:hover .mega-menu-content {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .nav-item-link::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1px;
            background-color: currentColor;
            transition: width 0.3s ease;
        }
        .group:hover .nav-item-link::after {
            width: 100%;
        }
    </style>
</head>
<body class="antialiased selection:bg-[#E5E5E0] selection:text-[#2C3333]">

    <!-- NAVBAR CON MEGA MENU -->
    <nav id="navbar" class="fixed w-full z-50 bg-transparent text-white py-6">
        <div class="max-w-screen-2xl mx-auto px-6 flex justify-between items-center">
            
            <!-- Logo -->
            <div class="text-left cursor-pointer z-20 flex-shrink-0" onclick="window.scrollTo(0,0)">
                <h1 class="font-serif text-2xl md:text-3xl tracking-widest uppercase">
                    Hotel du Soleil
                </h1>
            </div>

            <!-- Menu Desktop -->
            <ul class="hidden lg:flex gap-8 text-[11px] tracking-[0.15em] uppercase font-semibold h-full items-center z-20">
                
                <!-- Panoramica -->
                <li class="group py-6">
                    <a href="#" class="nav-item-link relative inline-block">Panoramica</a>
                    <div class="mega-menu-content bg-white text-alpine-text shadow-2xl border-t border-alpine-border cursor-default">
                        <div class="max-w-screen-2xl mx-auto px-6 py-12 grid grid-cols-12 gap-12">
                            <div class="col-span-3">
                                <h4 class="font-serif text-3xl mb-6 text-alpine-text capitalize tracking-normal">Panoramica</h4>
                                <ul class="space-y-4 text-sm font-normal normal-case tracking-normal">
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> La Struttura</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> La Nostra Storia</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Posizione & Dintorni</a></li>
                                    <li><a href="#" class="hover:text-alpine-gold transition-colors flex items-center gap-2"><i data-lucide="minus" class="w-4 h-4 text-alpine-gold"></i> Sostenibilità</a></li>
                                </ul>
                            </div>
                            <div class="col-span-4 flex flex-col justify-center border-l border-alpine-border pl-12 pr-6">
                                <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-alpine-muted mb-4">In Evidenza</span>
                                <p class="text-sm leading-relaxed text-alpine-muted mb-6">Scopri il fascino autentico di un rifugio a 1.500 metri. L'eleganza della semplicità e il calore di una gestione familiare dal 1980.</p>
                                <a href="#" class="text-xs font-bold uppercase tracking-widest text-alpine-text hover:text-alpine-gold transition-colors flex items-center gap-2">Scopri l'Hotel <i data-lucide="arrow-right" class="w-4 h-4"></i></a>
